# Copy this file to .env and fill values (DO NOT commit real secrets)
# Option A (recommended): place your service account JSON at the path below and set FIREBASE_SERVICE_ACCOUNT_PATH
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B (alternative): set the entire JSON as one-line string (less safe)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN...\n...\n-----END...\n",...}

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT used by backend auth routes (optional for this project)
JWT_SECRET=your_jwt_secret_here

